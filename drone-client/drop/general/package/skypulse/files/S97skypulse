#!/bin/sh
# /etc/init.d/S97skypulse — start skypulse-drone after WireGuard is up

DAEMON="/usr/bin/skypulse-drone"
PIDFILE="/var/run/skypulse-drone.pid"
CONFIG="/etc/skypulse.conf"

start() {
    # Disable any serial console on the FC UART before grabbing it.
    if grep -q "ttyS3" /etc/inittab 2>/dev/null; then
        sed -i 's/.*ttyS3.*/#&/' /etc/inittab
        kill -HUP 1 2>/dev/null
        echo "S97skypulse: disabled ttyS3 console"
    fi
    kill $(fuser /dev/ttyS3 2>/dev/null) 2>/dev/null || true

    # Wait for wg0 to exist (rc.local brings it up).
    for i in $(seq 1 10); do
        ip link show wg0 >/dev/null 2>&1 && break
        echo "S97skypulse: waiting for wg0... ($i/10)"
        sleep 2
    done

    ulimit -c unlimited
    echo "/tmp/core.skypulse" > /proc/sys/kernel/core_pattern

    echo -n "Starting skypulse-drone: "
    start-stop-daemon -b -m -S -q -p "$PIDFILE" -x "$DAEMON" -- $CONFIG
    [ $? -eq 0 ] && echo "OK" || echo "FAIL"
}

stop() {
    echo -n "Stopping skypulse-drone: "
    start-stop-daemon -K -q -p "$PIDFILE"
    [ $? -eq 0 ] && { rm -f "$PIDFILE"; echo "OK"; } || echo "FAIL"
}

case "$1" in
    start|stop) $1 ;;
    restart|reload) stop; sleep 2; start ;;
    *) echo "Usage: $0 {start|stop|restart}"; exit 1 ;;
esac
